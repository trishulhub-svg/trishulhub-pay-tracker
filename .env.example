# Local development uses SQLite file
DATABASE_URL=file:./db/custom.db

# Turso (production) - Get these from https://turso.tech
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.so
TURSO_AUTH_TOKEN=your-turso-auth-token

# Session security - Generate a random string (e.g., openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-string

# Brevo SMTP credentials - You can also configure these in Admin Settings UI
# Settings saved in the Admin UI take priority over these env vars
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=TrishulHub Pay Tracker
BREVO_SMTP_LOGIN=
BREVO_SMTP_SERVER=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
