generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  name             String
  password         String
  phone            String?
  role             String         @default("USER")
  referralCode     String         @unique
  referredBy       String?
  isPremium        Boolean        @default(false)
  premiumExpiresAt DateTime?
  termsAccepted    Boolean        @default(false)
  termsAcceptedAt  DateTime?
  emailVerified    Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  companies        Company[]
  paymentRecords   PaymentRecord[]
  shifts           Shift[]
  otpCodes         OtpCode[]
}

model Company {
  id             String          @id @default(cuid())
  name           String
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  paymentRecords PaymentRecord[]
  shifts         Shift[]

  @@unique([userId, name])
}

model PaymentRecord {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  month         Int
  year          Int
  totalExpected Float    @default(0)
  totalReceived Float    @default(0)
  totalHMRC     Float    @default(0)
  totalDue      Float    @default(0)
  workedHours   Float    @default(0)
  status        String   @default("PENDING")
  notes         String?
  paySlipUrl    String?
  paySlipName   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, companyId, month, year])
}

model Shift {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  date          String
  startTime     String
  endTime       String
  breakMinutes  Int      @default(0)
  totalHours    Float    @default(0)
  shiftType     String   @default("REGULAR")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String   // SIGNUP, PASSWORD_RESET
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?
}
